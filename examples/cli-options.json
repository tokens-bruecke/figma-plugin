{
  "$schema": "https://raw.githubusercontent.com/tokens-bruecke/figma-plugin/main/schemas/cli-options.schema.json",
  "includedStyles": {
    "text": {
      "isIncluded": true,
      "customName": "typography"
    },
    "effects": {
      "isIncluded": true,
      "customName": "effects"
    },
    "grids": {
      "isIncluded": false,
      "customName": "grids"
    },
    "colors": {
      "isIncluded": false,
      "customName": "colors"
    }
  },
  "includeScopes": false,
  "useDTCG": true,
  "includeValueStringKeyToAlias": true,
  "colorMode": "hsla-css",
  "storeStyleInCollection": "none"
}
